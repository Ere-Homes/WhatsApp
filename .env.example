# Twilio (from Twilio Console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# Your WhatsApp sender, E.164 with the whatsapp: prefix
TWILIO_WHATSAPP_FROM=whatsapp:+12202424577

# Supabase (the FRESH project for this app)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Audience CRM (read-only) - the big ERE contacts database used for segments
# and Inbox contact lookups.
CRM_SUPABASE_URL=https://xxxx.supabase.co
CRM_SUPABASE_KEY=your_crm_anon_key

# Google Sheet export of "not in CRM" recipients (optional).
# Uses a Google service account (Sheets API). See docs/google-sheet-export.md.
# Leave blank to disable (sends still work, just no logging).
GOOGLE_SA_EMAIL=your-sa@your-project.iam.gserviceaccount.com
# Paste the private_key from the SA JSON. Keep the \n escapes (one line) OR paste
# the real multi-line key wrapped in quotes - both are handled.
GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
SHEETS_SPREADSHEET_ID=the_long_id_from_the_sheet_url
SHEETS_TAB=Not in CRM
